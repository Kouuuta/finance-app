generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  createdAt    DateTime       @default(now())
  accounts     Account[]
  transactions Transaction[]
  categories   Category[]
  savingsGoals SavingsGoal[]
  investments  Investment[]
}

model Institution {
  id      String    @id @default(cuid())
  name    String    @unique
  type    String
  icon    String
  logoUrl String?
  accounts Account[]
}

model Account {
  id                      String       @id @default(cuid())
  userId                  String
  user                    User         @relation(fields: [userId], references: [id])
  name                    String
  type                    String
  institutionId           String?
  institution             Institution?  @relation(fields: [institutionId], references: [id])
  balance                 Float        @default(0)
  interestRateAnnual      Float?
  lastInterestAccrualDate DateTime?
  transactions            Transaction[]
  createdAt               DateTime     @default(now())
}

model Category {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  name         String
  type         String
  isDefault    Boolean       @default(false)
  transactions Transaction[]
}

model Transaction {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  accountId  String
  account    Account   @relation(fields: [accountId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  amount     Float
  type       String
  note       String?
  date       DateTime
  createdAt  DateTime  @default(now())
}

model SavingsGoal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  createdAt     DateTime  @default(now())
}

model Investment {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  name         String
  type         String
  symbol       String
  units        Float
  costBasis    Float
  currentPrice Float
  updatedAt    DateTime @updatedAt
}
